{
  "name": "@microsoft/snapfeed-server",
  "version": "0.1.0",
  "description": "Reference backend for @microsoft/snapfeed — Hono + SQLite telemetry server",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/integrations/nextjs.d.ts",
      "import": "./dist/integrations/nextjs.js",
      "require": "./dist/integrations/nextjs.cjs"
    },
    "./express": {
      "types": "./dist/integrations/express.d.ts",
      "import": "./dist/integrations/express.js",
      "require": "./dist/integrations/express.cjs"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "import": "./dist/security.js",
      "require": "./dist/security.cjs"
    }
  },
  "bin": {
    "snapfeed-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@microsoft/snapfeed": "^0.1.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/snapfeed": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "snapfeed",
    "telemetry",
    "server",
    "hono",
    "sqlite",
    "nextjs",
    "express"
  ],
  "license": "MIT"
}
