{
  "name": "@microsoft/snapfeed",
  "version": "0.2.0",
  "description": "UI feedback & telemetry for agentic workflows — capture clicks, errors, navigation, and visual feedback with framework-agnostic plugin support",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs"
    },
    "./global": {
      "default": "./dist/snapfeed.global.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@storybook/html-vite": "^10.3.3",
    "jsdom": "^26.1.0",
    "storybook": "^10.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.1"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "telemetry",
    "feedback",
    "ui",
    "agentic",
    "screenshot",
    "plugin",
    "github",
    "slack",
    "telegram"
  ],
  "license": "MIT"
}
